# Sao chép file này thành .env và điền giá trị thực tế
# File .env KHÔNG được commit vào git

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql://ems_admin:CHANGE_ME@localhost:5432/hust_ems

# ── JWT Secret Key ────────────────────────────────
# Tạo chuỗi ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_RANDOM_SECRET_MIN_32_CHARS

# ── Môi trường ────────────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=production
